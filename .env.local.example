# Copy this file to .env.local and fill in the values you need.

# === Map tiles ===
# MapTiler free tier: https://www.maptiler.com/cloud/  (sign up, copy the key)
# If you leave this blank, the app falls back to a no-key demo style that
# rate-limits aggressively. Fine for local dev, not for sharing.
NEXT_PUBLIC_MAPTILER_KEY=

# === Routing + isochrone provider ===
# "tfl" is the default route provider and uses TfL's public Journey Planner.
# "static" is available for offline local development. Driving-based
# providers are intentionally NOT supported: this app is public-transport-first.
ROUTING_PROVIDER=tfl
ISOCHRONE_PROVIDER=sampled

# === Convex (Stage 4) ===
# Leave empty until you're ready to add accounts & saved shortlists.
# To enable: run `npx convex dev` and paste the deployment URL it prints.
NEXT_PUBLIC_CONVEX_URL=
