# ─── Site URL ─────────────────────────────────────────────────────────────────
# The canonical base URL for the deployment.
# Must NOT have a trailing slash.
# Used by: sitemap.xml, canonical tags, OpenGraph URLs.
#
# In Vercel: Settings → Environment Variables → Add "NEXT_PUBLIC_SITE_URL"
# Set it to your production domain, e.g. https://london-borough.vercel.app
#
NEXT_PUBLIC_SITE_URL=https://london-borough.vercel.app

# ─── Routing provider ─────────────────────────────────────────────────────────
# "tfl"    — live TfL Journey Planner (default, no key required)
# "static" — offline distance heuristic (useful for local dev without network)
#
# ROUTING_PROVIDER=static

# ─── Google Search Console ────────────────────────────────────────────────────
# After deploying, submit your sitemap at:
#   https://search.google.com/search-console
#   Property → Sitemaps → Add: /sitemap.xml
#
# The google verification HTML file (google2d6c144debbc7c91.html) is already
# in /public — just redeploy and verify via the "HTML file" method.
